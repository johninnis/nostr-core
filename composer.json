{
    "name": "innis/nostr-core",
    "description": "Core domain entities and services for Nostr protocol implementation",
    "type": "library",
    "license": "MIT",
    "keywords": ["nostr", "protocol", "core", "domain"],
    "authors": [
        {
            "name": "John Innis",
            "email": "john@innis.xyz",
            "homepage": "https://www.innis.xyz/"
        }
    ],
    "require": {
        "php": "^8.1",
        "paragonie/ecc": "^2.5",
        "nostriphant/nip-19": "^2.0",
        "psr/log": "^3.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "phpstan/phpstan": "^1.12",
        "friendsofphp/php-cs-fixer": "^3.85"
    },
    "autoload": {
        "psr-4": {
            "Innis\\Nostr\\Core\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Innis\\Nostr\\Core\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "XDEBUG_MODE=coverage phpunit",
        "analyse": "phpstan analyse",
        "fix-style": "php-cs-fixer fix",
        "check-style": "php-cs-fixer fix --dry-run --diff"
    }
}
